{
  "manifest_version": 3,
  "name": "SnippetVault",
  "version": "1.0.0",
  "description": "A categorized clipboard and snippet manager.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open SnippetVault"
  },
  "permissions": ["storage", "clipboardWrite"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
